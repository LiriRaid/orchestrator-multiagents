{
  "name": "@liriraid/orchestrator-multiagents",
  "version": "1.0.0",
  "description": "TUI dashboard para orquestar múltiples agentes de IA de código trabajando en paralelo sobre tu codebase",
  "author": "LiriRaid",
  "homepage": "https://github.com/LiriRaid/orchestrator-multiagents#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LiriRaid/orchestrator-multiagents.git"
  },
  "bugs": {
    "url": "https://github.com/LiriRaid/orchestrator-multiagents/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "orchestrator.js",
  "bin": {
    "orchestrator": "./orchestrator.js",
    "orchestrator-multiagents": "./bin/orchestrator-multiagents.mjs"
  },
  "files": [
    "bin",
    "src",
    "agents",
    "openspec",
    ".claude",
    ".codex",
    ".opencode",
    "scripts",
    "orchestrator.js",
    "orchestrator.config.json",
    "ORCHESTRATOR.md",
    "CLAUDE.md",
    "ENGRAM.md",
    "AGENT-CONFIG.md",
    "QUEUE.md"
  ],
  "scripts": {
    "start": "node orchestrator.js",
    "start:paused": "node orchestrator.js --paused",
    "start:ink": "node src/ink/index.mjs",
    "start:ink:paused": "node src/ink/index.mjs --paused",
    "skills:registry": "node scripts/update-skill-registry.mjs",
    "openspec:new": "node scripts/scaffold-openspec-change.mjs",
    "agent-config:init": "node scripts/scaffold-agent-configs.mjs",
    "cli:help": "node bin/orchestrator-multiagents.mjs --help"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestrator",
    "orchestrator-multiagents",
    "claude",
    "codex",
    "gemini",
    "cursor",
    "opencode",
    "abacus",
    "tui",
    "multi-agent",
    "coding-assistant",
    "openspec",
    "engram",
    "skills",
    "agent-config"
  ],
  "license": "MIT",
  "dependencies": {
    "blessed": "^0.1.81",
    "ink": "^5.2.1",
    "react": "^18.3.1"
  }
}
